# ─────────────────────────────────────────────────────────────────────────────
# TechMart AI Customer Support — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose one: groq | openai | ollama
LLM_PROVIDER=groq

# Groq (FREE — fastest option, recommended for development)
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI (optional — comment out if using Groq)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-3.5-turbo
# LLM_PROVIDER=openai

# Ollama (local, no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1
# LLM_PROVIDER=ollama

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_IN_PRODUCTION
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default — no setup needed)
DATABASE_URL=sqlite:///./customer_support.db

# PostgreSQL (production — comment in to use)
# DATABASE_URL=postgresql://user:password@localhost:5432/techmart_support

# ── RAG Settings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=600
CHUNK_OVERLAP=80
TOP_K_RESULTS=4

# ── LLM Generation Settings ────────────────────────────────────────────────────
MAX_TOKENS=600
TEMPERATURE=0.7

# ── Application ────────────────────────────────────────────────────────────────
DEBUG=false

# Comma-separated browser origins permitted to call the API
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
